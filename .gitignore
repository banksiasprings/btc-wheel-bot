# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Environment / secrets — NEVER commit these
.env
*.env
.env.*
!.env.example

# Deribit API credentials — NEVER commit
config/deribit_testnet.json

# Kill switch (runtime file)
KILL_SWITCH

# Bot runtime outputs
logs/
data/
backtest_results.png

# Exception: the raw-data schema doc is a source artifact, not a data file.
# Re-include the root `data/raw/` path narrowly so git can descend just far
# enough to track the README — `legacy_options/*/data/` and every other
# nested data/ directory stays ignored.
!/data/
/data/*
!/data/raw/
/data/raw/*
!/data/raw/README.md

# Optimizer outputs
sweep_sensitivity.png
evolution_progress.png
evolution_leaderboard.csv
best_genome.yaml

# Docker
.dockerignore

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp

# Phase 3 training run artifacts (keep code + checkpoints, ignore TB logs)
training/logs/

# Grid-bot farm runtime (regenerated by grid_farm.py — not source)
grid_farm/
strategies/paper_state.json
strategies/paper_live.log

# RL training artifacts — large + regenerable, kept local (abandoned direction)
rl_agent/checkpoints/
rl_agent/*.log
rl_agent/*.zip
rl_agent/run-1-*/
