# ── Deribit Credentials ──────────────────────────────────────────────────────
# Get these from: https://www.deribit.com/account/api
# Never commit real credentials to version control.
DERIBIT_API_KEY=your_api_key_here
DERIBIT_API_SECRET=your_api_secret_here

# Use testnet for development (overrides config.yaml deribit.testnet)
DERIBIT_TESTNET=true

# ── Mobile API ───────────────────────────────────────────────────────────────
# Auto-generated by api.py on first run — copy from .env after generation
WHEEL_API_KEY=

# ── Telegram Alerts ──────────────────────────────────────────────────────────
# Optional — alerts for drawdown, IV spikes, trade opens/closes
# Get bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional LLM Overseer ─────────────────────────────────────────────────────
# Set one of these to enable the AI Overseer (Gemini free tier recommended)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Optional Overrides ───────────────────────────────────────────────────────
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
